# Slack — get these from api.slack.com/apps after creating the app
# (See manifest.yaml for the app definition.)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...   # Socket Mode app-level token, starts with xapp-

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ora config
ORA_DB_PATH=./ora.db
ORA_CHANNEL_ID=                # Slack channel ID for #ora (C0XXXXXX). Daily fortune posts here.
ORA_DAILY_FORTUNE_HOUR=9       # local hour (24h) to post daily fortune
ORA_TIMEZONE=Asia/Seoul        # for scheduler and date marker on daily posts
ORA_MODEL_DEFAULT=claude-sonnet-4-6
ORA_MODEL_DEEP=claude-opus-4-7
