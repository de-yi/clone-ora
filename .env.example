# Slack — get these from api.slack.com/apps after creating the app
# (See manifest.yaml for the app definition.)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...   # Socket Mode app-level token, starts with xapp-

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ora config
ORA_DB_PATH=./ora.db
ORA_CHANNEL_ID=                # Slack channel ID for #ora (C0XXXXXX). Daily fortune posts here.
ORA_DAILY_FORTUNE_HOUR=9       # local hour (24h) to post daily fortune
ORA_TIMEZONE=Asia/Seoul        # for scheduler and date marker on daily posts
ORA_MODEL_DEFAULT=claude-sonnet-4-6
ORA_MODEL_DEEP=claude-opus-4-7
ORA_MODEL_DIGEST=claude-haiku-4-5    # cheap model that rewrites the per-subject memory note

# Memory
ORA_THREAD_HISTORY_LIMIT=15          # messages pulled from a thread for runtime context
ORA_DM_HISTORY_LIMIT=20              # messages pulled from a DM for runtime context
ORA_MEMORY_DEBOUNCE_SECONDS=60       # min gap between digest rewrites for the same subject
ORA_MEMORY_READINGS_WINDOW=25        # how many recent readings the digest call considers
